# Copy to .env.local and fill in from Supabase → Project Settings → API
# Never commit .env.local (it is gitignored).

# Project URL, e.g. https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=

# Publishable key (safe in the browser) — starts with sb_publishable_
# Or legacy "anon" JWT from API Keys → Legacy tab
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional: for npm run db:migrate:002 (Settings -> Database -> Connection string -> URI)
# SUPABASE_DB_URL=
